    {
      "title": "Overall Throughput (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"beyou-backend\"}[1m]))", "legendFormat": "total req/s", "refId": "A" }
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"beyou-backend\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"beyou-backend\"}[1m]))", "legendFormat": "5xx", "refId": "A" }
      ]
    },
